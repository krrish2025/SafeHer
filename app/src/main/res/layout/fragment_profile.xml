<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface">

    <!-- PROFILE SECTION -->
    <LinearLayout
        android:id="@+id/profileSection"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:paddingTop="32dp"
        android:paddingBottom="16dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <FrameLayout
            android:layout_width="72dp"
            android:layout_height="72dp">

            <ImageView
                android:id="@+id/profileImage"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/bg_avatar_large"
                android:scaleType="centerCrop"
                android:clipToOutline="true" />

            <TextView
                android:id="@+id/profileInitials"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="RS"
                android:textColor="@android:color/white"
                android:textSize="20sp"
                android:textStyle="bold" />
        </FrameLayout>

        <TextView
            android:id="@+id/profileName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Riya Sharma"
            android:textColor="@color/text"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/profileEmail"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="riya@example.com"
            android:textColor="@color/sub"
            android:textSize="12sp" />

    </LinearLayout>

    <!-- SETTINGS CARD -->
    <LinearLayout
        android:id="@+id/settingsCard"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/bg_panel_rounded_14"
        android:paddingVertical="8dp"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/profileSection"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Trusted Contacts -->
        <LinearLayout
            android:id="@+id/rowPhone"
            style="@style/ProfileRow"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackground">
            <TextView style="@style/ProfileRowLabel" android:text="Phone Number" />
            <TextView android:id="@+id/profilePhoneText" style="@style/ProfileBadge" android:text="Add Phone" android:textColor="@color/ember" />
            <TextView style="@style/ProfileChevron" android:text="›" />
        </LinearLayout>

        <View style="@style/ProfileDivider" />

        <!-- Trusted Contacts -->
        <LinearLayout
            android:id="@+id/rowGuardians"
            style="@style/ProfileRow"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackground">
            <TextView style="@style/ProfileRowLabel" android:text="Trusted Contacts" />
            <TextView android:id="@+id/guardianCount" style="@style/ProfileBadge" android:text="0" />
            <TextView style="@style/ProfileChevron" android:text="›" />
        </LinearLayout>

        <View style="@style/ProfileDivider" />

        <!-- Community Member Mode -->
        <LinearLayout style="@style/ProfileRow">
            <TextView style="@style/ProfileRowLabel" android:text="Community Hero Mode" />
            <androidx.appcompat.widget.SwitchCompat
                android:id="@+id/communityModeToggle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:thumb="@drawable/switch_thumb"
                app:track="@drawable/switch_track" />
        </LinearLayout>

        <View style="@style/ProfileDivider" />

        <!-- My Reports -->
        <LinearLayout
            android:id="@+id/rowReports"
            style="@style/ProfileRow"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackground">
            <TextView style="@style/ProfileRowLabel" android:text="My Reports" />
            <TextView android:id="@+id/reportCount" style="@style/ProfileBadge" android:text="0" />
            <TextView style="@style/ProfileChevron" android:text="›" />
        </LinearLayout>

        <View style="@style/ProfileDivider" />

        <!-- Notifications -->
        <LinearLayout
            android:id="@+id/rowNotifications"
            style="@style/ProfileRow"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackground">
            <TextView style="@style/ProfileRowLabel" android:text="Notifications" />
            <TextView style="@style/ProfileChevron" android:text="›" />
        </LinearLayout>

    </LinearLayout>

    <!-- LOGOUT BUTTON -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/logoutButton"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Log Out"
        android:textAllCaps="false"
        android:textStyle="bold"
        android:textColor="@color/ember"
        android:layout_margin="16dp"
        app:backgroundTint="@color/panel"
        app:cornerRadius="12dp"
        app:strokeColor="@color/ember"
        app:strokeWidth="1dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>