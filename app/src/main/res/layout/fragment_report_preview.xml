<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="20dp"
        android:paddingTop="49dp"
        android:paddingBottom="24dp">

        <!-- HEADER -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingTop="20sp"
            android:layout_marginBottom="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Review Report"
                android:textColor="@color/text"
                android:textSize="20sp"
                android:textStyle="bold" />
        </RelativeLayout>

        <!-- CATEGORY -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Category"
            android:textColor="@color/sub"
            android:textSize="12sp"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/previewCategory"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_panel_rounded"
            android:padding="12dp"
            android:text="Harassment"
            android:textColor="@color/text"
            android:textSize="16sp" />

        <!-- DESCRIPTION -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Description"
            android:textColor="@color/sub"
            android:textSize="12sp"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/previewDescription"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="100dp"
            android:background="@drawable/bg_panel_rounded"
            android:padding="12dp"
            android:text="Description goes here..."
            android:textColor="@color/text"
            android:textSize="14sp" />

        <!-- EVIDENCE -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Evidence"
            android:textColor="@color/sub"
            android:textSize="12sp"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="8dp" />

        <ImageView
            android:id="@+id/previewEvidence"
            android:layout_width="match_parent"
            android:layout_height="180dp"
            android:background="@drawable/bg_panel_rounded"
            android:scaleType="centerCrop"
            android:visibility="gone" />

        <TextView
            android:id="@+id/noEvidenceText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_panel_rounded"
            android:padding="12dp"
            android:text="No evidence attached"
            android:textColor="@color/sub"
            android:textSize="14sp" />

        <!-- LOCATION -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Location"
            android:textColor="@color/sub"
            android:textSize="12sp"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/previewLocation"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_panel_rounded"
            android:padding="12dp"
            android:text="Latitude: 0.0, Longitude: 0.0"
            android:textColor="@color/text"
            android:textSize="14sp" />

        <!-- ACTIONS -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/editButton"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:backgroundTint="@color/panel"
                android:text="Edit"
                android:textAllCaps="false"
                android:textColor="@color/text"
                app:cornerRadius="14dp"
                app:strokeColor="@color/border"
                app:strokeWidth="1dp" />

            <Button
                android:id="@+id/confirmButton"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_weight="1.5"
                android:layout_marginStart="8dp"
                android:backgroundTint="@color/ember"
                android:text="Confirm &amp; Submit"
                android:textAllCaps="false"
                android:textColor="@color/white"
                android:textStyle="bold"
                app:cornerRadius="14dp" />
        </LinearLayout>

    </LinearLayout>

</androidx.core.widget.NestedScrollView>