<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="20dp"
        android:paddingTop="40dp"
        android:paddingBottom="24dp">

        <!-- HEADER -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingTop="20sp"
            android:layout_marginBottom="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Report Incident"
                android:textColor="@color/text"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:background="@drawable/bg_blockchain_badge"
                android:paddingHorizontal="10dp"
                android:paddingVertical="4dp"
                android:text="Blockchain secured"
                android:textColor="@color/ember"
                android:textSize="10sp" />
        </RelativeLayout>

        <!-- CATEGORY -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Category"
            android:textColor="@color/sub"
            android:textSize="12sp"
            android:layout_marginBottom="8dp" />

        <RadioGroup
            android:id="@+id/categoryGroup"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <GridLayout
                android:id="@+id/categoryGrid"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:columnCount="2"
                android:useDefaultMargins="true">

                <RadioButton
                    android:id="@+id/btnHarassment"
                    style="@style/Widget.Material3.CompoundButton.RadioButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:background="@drawable/selector_report_category"
                    android:button="@null"
                    android:gravity="center"
                    android:padding="12dp"
                    android:text="Harassment"
                    android:textColor="@color/text" />

                <RadioButton
                    android:id="@+id/btnStalking"
                    style="@style/Widget.Material3.CompoundButton.RadioButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:background="@drawable/selector_report_category"
                    android:button="@null"
                    android:gravity="center"
                    android:padding="12dp"
                    android:text="Stalking"
                    android:textColor="@color/text" />

                <RadioButton
                    android:id="@+id/btnSuspicious"
                    style="@style/Widget.Material3.CompoundButton.RadioButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:background="@drawable/selector_report_category"
                    android:button="@null"
                    android:gravity="center"
                    android:padding="12dp"
                    android:text="Suspicious"
                    android:textColor="@color/text" />

                <RadioButton
                    android:id="@+id/btnOther"
                    style="@style/Widget.Material3.CompoundButton.RadioButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:background="@drawable/selector_report_category"
                    android:button="@null"
                    android:gravity="center"
                    android:padding="12dp"
                    android:text="Other"
                    android:textColor="@color/text" />
            </GridLayout>
        </RadioGroup>

        <!-- OTHER INPUT -->
        <EditText
            android:id="@+id/otherCategoryInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_panel_rounded"
            android:hint="Enter the issue"
            android:padding="12dp"
            android:visibility="gone"
            android:textColor="@color/text"
            android:textColorHint="@color/sub"
            android:textSize="14sp" />

        <!-- DESCRIPTION -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Description"
            android:textColor="@color/sub"
            android:textSize="12sp"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="8dp" />

        <EditText
            android:id="@+id/descriptionInput"
            android:layout_width="match_parent"
            android:layout_height="120dp"
            android:background="@drawable/bg_panel_rounded"
            android:gravity="top"
            android:hint="Tell us what happened..."
            android:padding="14dp"
            android:textColor="@color/text"
            android:textColorHint="@color/sub"
            android:textSize="14sp" />

        <!-- EVIDENCE -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Evidence"
            android:textColor="@color/sub"
            android:textSize="12sp"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="8dp" />

        <FrameLayout
            android:id="@+id/evidenceUpload"
            android:layout_width="match_parent"
            android:layout_height="100dp"
            android:background="@drawable/bg_dashed_border">

            <ImageView
                android:id="@+id/evidenceImage"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:visibility="gone" />

            <TextView
                android:id="@+id/uploadPlaceholder"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="Tap to upload photo"
                android:textColor="@color/sub"
                android:textSize="13sp" />
        </FrameLayout>

        <!-- LOCATION -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Location"
            android:textColor="@color/sub"
            android:textSize="12sp"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="8dp" />

        <LinearLayout
            android:id="@+id/locationPicker"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_safe_glow_rounded"
            android:clickable="true"
            android:focusable="true"
            android:padding="12dp">

            <TextView
                android:id="@+id/locationText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Select location of the incident"
                android:textColor="@color/safe"
                android:textSize="13sp" />
        </LinearLayout>

        <!-- SUBMIT BUTTON -->
        <Button
            android:id="@+id/submitButton"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="28dp"
            android:backgroundTint="@color/ember"
            android:text="Submit Report →"
            android:textAllCaps="false"
            android:textColor="@color/white"
            android:textSize="15sp"
            android:textStyle="bold"
            android:elevation="6dp"
            app:cornerRadius="14dp" />

    </LinearLayout>

</androidx.core.widget.NestedScrollView>
